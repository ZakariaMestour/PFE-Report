@startuml
<style>
root {
  FontName Inter, Roboto, Helvetica, sans-serif
  FontSize 14
  FontColor #333333
}
document {
  BackgroundColor white
}
</style>
skinparam shadowing false
skinparam linetype ortho
skinparam monochrome true
title Main SCF Class Diagram

class ScfProductDefinition {
  +code: String
  +type: ProductType
  +instrument: Instrument
  +status: ApprovalStatus
}
class ScfProgramConfiguration {
  +id: UUID
  +reference: String
  +currency: Currency
  +financePercent: BigDecimal
  +status: ProgramStatus
}
class ScfProgramAnchor {
  +roleInProgram: String
  +active: Boolean
  +approvalStatus: ApprovalStatus
}
class ScfAnchor {
  +anchorCode: String
  +name: String
  +role: AnchorRole
}
class ScfCounterParty {
  +legalName: String
  +role: CounterpartyRole
  +status: CounterPartyStatus
  +taxIdentifier: String
}
class ScfProgramCounterParty {
  +roleInProgram: String
  +limitAmount: BigDecimal
  +active: Boolean
}
class ScfBankAccount {
  +iban: String
  +swiftCode: String
  +currency: Currency
  +primaryAccount: Boolean
}
class ScfProgramFeeCatalogue {
  +feeItems: List
  +flatFeeConfig: FlatFeeConfig
  +approvalStatus: ApprovalStatus
}
class ScfProgramCashflow {
  +autoDisbursement: Boolean
  +autoRepayment: Boolean
  +multipleDisbursement: Boolean
  +maxDisbursementsAllowed: Integer
  +repaymentBy: String
}
class CountryMaster {
  +countryCodeIso2: String
  +countryCodeIso3: String
  +countryName: String
}
class CityMaster {
  +cityCode: String
  +cityName: String
  +countryCodeIso2: String
}
ScfProductDefinition "1" --> "0..*" ScfProgramConfiguration : defines
ScfProgramConfiguration "1" *-- "0..1" ScfProgramAnchor : anchor assignment
ScfProgramAnchor "0..*" --> "1" ScfAnchor : references
ScfProgramConfiguration "1" *-- "0..*" ScfProgramCounterParty : program parties
ScfProgramCounterParty "0..*" --> "1" ScfCounterParty : references
ScfCounterParty "1" *-- "0..*" ScfBankAccount : owns
ScfProgramConfiguration "1" *-- "0..1" ScfProgramCashflow : cashflow settings
ScfProgramConfiguration "1" *-- "0..1" ScfProgramFeeCatalogue : fee settings
CountryMaster "1" --> "0..*" CityMaster : contains
ScfCounterParty "0..*" ..> "0..1" CountryMaster : address country

@enduml
