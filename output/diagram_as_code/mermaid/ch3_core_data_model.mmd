%%{init: { 'theme': 'neutral', 'themeVariables': { 'fontFamily': 'Inter, Roboto, Helvetica, sans-serif', 'fontSize': '16px', 'fontWeight': '500' } } }%%
classDiagram
    class ScfProductDefinition {
        +String code
        +ProductType type
        +Instrument instrument
        +ApprovalStatus status
    }
    class ScfProgramConfiguration {
        +UUID id
        +String reference
        +Currency currency
        +BigDecimal financePercent
        +ProgramStatus status
    }
    class ScfProgramAnchor {
        +String roleInProgram
        +Boolean active
        +ApprovalStatus approvalStatus
    }
    class ScfAnchor {
        +String anchorCode
        +String name
        +AnchorRole role
    }
    class ScfCounterParty {
        +String legalName
        +CounterpartyRole role
        +CounterPartyStatus status
        +String taxIdentifier
    }
    class ScfProgramCounterParty {
        +String roleInProgram
        +BigDecimal limitAmount
        +Boolean active
    }
    class ScfBankAccount {
        +String iban
        +String swiftCode
        +Currency currency
        +Boolean primaryAccount
    }
    class ScfProgramFeeCatalogue {
        +List feeItems
        +FlatFeeConfig flatFeeConfig
        +ApprovalStatus approvalStatus
    }
    class ScfProgramCashflow {
        +Boolean autoDisbursement
        +Boolean autoRepayment
        +Boolean multipleDisbursement
        +Integer maxDisbursementsAllowed
        +String repaymentBy
    }
    class CountryMaster {
        +String countryCodeIso2
        +String countryCodeIso3
        +String countryName
    }
    class CityMaster {
        +String cityCode
        +String cityName
        +String countryCodeIso2
    }
    ScfProductDefinition "1" --> "0..*" ScfProgramConfiguration : defines
    ScfProgramConfiguration "1" *-- "0..1" ScfProgramAnchor : anchor assignment
    ScfProgramAnchor "0..*" --> "1" ScfAnchor : references
    ScfProgramConfiguration "1" *-- "0..*" ScfProgramCounterParty : program parties
    ScfProgramCounterParty "0..*" --> "1" ScfCounterParty : references
    ScfCounterParty "1" *-- "0..*" ScfBankAccount : owns
    ScfProgramConfiguration "1" *-- "0..1" ScfProgramCashflow : cashflow settings
    ScfProgramConfiguration "1" *-- "0..1" ScfProgramFeeCatalogue : fee settings
    CountryMaster "1" --> "0..*" CityMaster : contains
    ScfCounterParty "0..*" ..> "0..1" CountryMaster : address country
